# Disable directory listing
Options -Indexes

# Block direct access to sensitive files
<FilesMatch "(^\.env|\.env\.example|\.md)$">
    Require all denied
</FilesMatch>

# Block access to DB scripts
<FilesMatch "\.sql$">
    Require all denied
</FilesMatch>

# Block access to the db/ directory entirely
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^db/ - [F,L]
</IfModule>
